\section*{\textcolor{blue}{2. API OpenWeather – Current Weather}}

\begin{longtable}{@{}ll@{}}
\toprule
\textbf{Campo} & \textbf{Descrição} \\ \midrule
\endhead
coord.lat, coord.lon & Latitude e longitude \\
weather[].id & Código da condição climática \\
weather[].main & Tipo geral do clima \\
weather[].description & Descrição detalhada \\
weather[].icon & Ícone da condição climática \\
main.temp, feels\_like & Temperatura e sensação térmica (\textdegree C) \\
main.temp\_min, temp\_max & Temperaturas mín./máx.\ observadas (\textdegree C) \\
main.pressure & Pressão (hPa) \\
main.humidity & Umidade (\%) \\
main.sea\_level, grnd\_level & Pressão ao nível do mar/solo (hPa) \\
visibility & Visibilidade (m) \\
wind.speed, wind.deg, wind.gust & Velocidade, direção, rajada do vento \\
clouds.all & Cobertura de nuvens (\%) \\
rain.1h, snow.1h & Chuva/Neve última hora (mm) \\
dt & Timestamp (Unix UTC) \\
sys.country, sunrise, sunset & País, nascer/pôr do sol \\
timezone & Diferença de fuso (s) \\
name, id, cod & Cidade, ID e status \\ \bottomrule
\end{longtable}

