% Detalhamento das Funções
\section*{\faCog~Detalhamento das Funções}

\subsection*{1️⃣~run\_script (Dados Meteorológicos RG Pilots)}
\begin{itemize}
    \item \textbf{Descrição:} Coleta dados meteorológicos de múltiplos providers (\texttt{controls}, \texttt{hidromares}, \texttt{getmare}) a cada 5 minutos.
    \item \textbf{Destino:} Tabela BigQuery \texttt{local-bliss-359814.wherehouse.update\_rawdata\_5min}
    \item \textbf{Destaques:}
    \begin{itemize}
        \item Deduplicação ocorre posteriormente no BigQuery via MERGE.
        \item Normaliza fusos para UTC-3 (Brasília) e timestamps a cada 5 minutos.
        \item Logging detalhado.
    \end{itemize}
\end{itemize}

\begin{tcolorbox}[colback=gray!7!white, title=Deploy]
\texttt{gcloud functions deploy run\_script \textbackslash \\
  --entry-point run\_script \textbackslash \\
  --runtime python310 \textbackslash \\
  --trigger-topic rgpilots-trigger \textbackslash \\
  --region=southamerica-east1 \textbackslash \\
  --memory=512MB \textbackslash \\
  --gen2}
\end{tcolorbox}

\begin{tcolorbox}[colback=cloudblue!7!white, title=Testar]
\texttt{gcloud pubsub topics publish rgpilots-trigger --message="\{\}"}
\end{tcolorbox}

\begin{tcolorbox}[colback=bqred!7!white, title=Consultar dados]
\texttt{SELECT * FROM \`local-bliss-359814.wherehouse.update\_rawdata\_5min\` \\
ORDER BY timestamp DESC \\
LIMIT 50;}
\end{tcolorbox}

\vspace{1em}

\subsection*{2️⃣~openweather-collector-v2 (Tempo Atual - OpenWeather)}
\begin{itemize}
    \item \textbf{Descrição:} Coleta condições atuais do tempo para uma lista de cidades.
    \item \textbf{Destino:} Tabela BigQuery \texttt{local-bliss-359814.wherehouse.dados\_openwhather}
    \item \textbf{Configuração via env:} \texttt{OPENWEATHER\_API\_KEY} e \texttt{BQ\_TABLE\_ID}
\end{itemize}

\begin{tcolorbox}[colback=gray!7!white, title=Deploy]
\texttt{gcloud functions deploy openweather-collector-v2 \textbackslash \\
  --gen2 \textbackslash \\
  --region southamerica-east1 \textbackslash \\
  --runtime python311 \textbackslash \\
  --source . \textbackslash \\
  --entry-point run\_script \textbackslash \\
  --memory 512MB \textbackslash \\
  --timeout 60s \textbackslash \\
  --trigger-topic openweather-trigger \textbackslash \\
  --set-env-vars "OPENWEATHER\_API\_KEY=xxxx,BQ\_TABLE\_ID=local-bliss-359814.wherehouse.dados\_openwhather"}
\end{tcolorbox}

\begin{tcolorbox}[colback=cloudblue!7!white, title=Agendamento]
\texttt{gcloud scheduler jobs create pubsub openweather-every-5min \textbackslash \\
  --schedule "*/5 * * * *" \textbackslash \\
  --topic openweather-trigger \textbackslash \\
  --message-body "\{\}" \textbackslash \\
  --time-zone "America/Sao\_Paulo" \textbackslash \\
  --location southamerica-east1}
\end{tcolorbox}

\begin{tcolorbox}[colback=bqred!7!white, title=Consultar dados]
\texttt{SELECT * FROM \`local-bliss-359814.wherehouse.dados\_openwhather\` \\
ORDER BY timestamp\_utc DESC \\
LIMIT 50;}
\end{tcolorbox}

\vspace{1em}

